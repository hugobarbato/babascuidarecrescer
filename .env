# ============================================================
# Configurações de E-mail — Gmail SMTP (Nodemailer)
# ============================================================
# 1. Acesse myaccount.google.com → Segurança
# 2. Ative a Verificação em 2 etapas (obrigatório)
# 3. Busque "Senhas de app" e crie uma senha para "E-mail / Outro"
# 4. Cole os 16 caracteres (sem espaços) em GMAIL_APP_PASSWORD abaixo
# ============================================================

GMAIL_USER=espacocuidarecrescer@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# E-mail de destino das notificações da empresa (padrão: igual ao GMAIL_USER)
COMPANY_EMAIL=espacocuidarecrescer@gmail.com

# reCAPTCHA v2 (Google) — anti-bot
# Registre em: https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
