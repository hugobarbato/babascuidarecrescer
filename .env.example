# ============================================================
# Configurações de E-mail — Resend
# ============================================================
# 1. Acesse resend.com e crie uma conta
# 2. Adicione e verifique seu domínio em "Domains"
# 3. Gere uma API Key em "API Keys"
# 4. Defina RESEND_FROM_EMAIL com um remetente do domínio verificado
#    Exemplo: "Cuidar & Crescer <noreply@seudominio.com.br>"
# ============================================================

# E-mail de destino das notificações da empresa
COMPANY_EMAIL=seu-email-de-resposta@exemplo.com

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Nome da Empresa <noreply@seudominio.com.br>

# reCAPTCHA v3 — anti-bot invisível (score 0.0–1.0)
# Registre em: https://www.google.com/recaptcha/admin
# VITE_RECAPTCHA_SITE_KEY → chave pública (exposta ao frontend via Vite)
# RECAPTCHA_SECRET_KEY    → chave secreta (somente server-side)
VITE_RECAPTCHA_SITE_KEY=sua-chave-publica-aqui
RECAPTCHA_SECRET_KEY=sua-chave-secreta-aqui
